<UserControl
    x:Class="WebFeedReader.Controls.CustomCheckBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WebFeedReader.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Root"
    mc:Ignorable="d">

    <Border>
        <CheckBox
            Command="{Binding ElementName=Root, Path=Command}"
            CommandParameter="{Binding ElementName=Root, Path=CommandParameter}"
            IsChecked="{Binding ElementName=Root, Path=IsChecked}">
            <CheckBox.Style>
                <Style TargetType="CheckBox">
                    <Setter Property="Background" Value="{StaticResource DarkBackgroundColor}" />
                    <Setter Property="Foreground" Value="#DCDCDC" />
                    <Setter Property="FontSize" Value="14" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="CheckBox">
                                <Grid x:Name="RootGrid" Background="Transparent">
                                    <StackPanel Orientation="Horizontal">
                                        <Grid VerticalAlignment="Center">
                                            <Border
                                                x:Name="BoxOuter"
                                                Width="50"
                                                Height="20"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="#454545"
                                                BorderThickness="1.5"
                                                CornerRadius="4" />

                                            <Path
                                                x:Name="CheckMark"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Data="M 4,10 L 8,14 L 16,6"
                                                Opacity="1"
                                                Stretch="Uniform"
                                                Stroke="DeepSkyBlue"
                                                StrokeDashArray="40,40"
                                                StrokeDashOffset="40"
                                                StrokeEndLineCap="Round"
                                                StrokeThickness="2.5" />
                                        </Grid>

                                        <ContentPresenter
                                            x:Name="ContentSite"
                                            Margin="10,0,0,0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="CheckMark" Property="Opacity" Value="1" />
                                        <Setter TargetName="BoxOuter" Property="BorderBrush" Value="DeepSkyBlue" />
                                    </Trigger>

                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BoxOuter" Property="BorderBrush" Value="#808080" />
                                    </Trigger>

                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.4" />
                                    </Trigger>

                                    <Trigger Property="IsChecked" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="CheckMark"
                                                        Storyboard.TargetProperty="StrokeDashOffset"
                                                        From="40"
                                                        To="0"
                                                        Duration="0:0:0.3" />
                                                    <ColorAnimation
                                                        Storyboard.TargetName="BoxOuter"
                                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                        To="DeepSkyBlue"
                                                        Duration="0:0:0.2" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>

                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="CheckMark"
                                                        Storyboard.TargetProperty="StrokeDashOffset"
                                                        To="40"
                                                        Duration="0:0:0" />
                                                    <ColorAnimation
                                                        Storyboard.TargetName="BoxOuter"
                                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                        To="#454545"
                                                        Duration="0:0:0.1" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>

                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BoxOuter" Property="BorderBrush" Value="#808080" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </CheckBox.Style>
        </CheckBox>
    </Border>
</UserControl>
<UserControl
    x:Class="WebFeedReader.Views.FeedSourceCreatePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:WebFeedReader.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:FeedSourceCreatePageViewModel}"
    d:DesignHeight="300"
    d:DesignWidth="300"
    Background="{StaticResource WindowBackgroundBrush}"
    mc:Ignorable="d">
    <Grid Margin="4">
        <Grid.Resources>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource CommonForegroundBrush}" />
                <Setter Property="FontSize" Value="{StaticResource CommonFontSize}" />
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="Foreground" Value="{StaticResource CommonForegroundBrush}" />
                <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}" />
                <Setter Property="FontSize" Value="{StaticResource CommonFontSize}" />
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <StackPanel.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="{StaticResource CommonForegroundBrush}" />
                    <Setter Property="FontSize" Value="{StaticResource CommonFontSize}" />
                    <Setter Property="Width" Value="120" />
                </Style>

                <Style TargetType="DockPanel">
                    <Setter Property="Margin" Value="0,3" />
                </Style>
            </StackPanel.Resources>

            <DockPanel>
                <TextBlock Text="PageTitle" />
                <TextBox Text="{Binding PageTitle}" />
            </DockPanel>

            <DockPanel>
                <TextBlock Text="Url" />
                <TextBox Text="{Binding Url}" />
            </DockPanel>

            <DockPanel>
                <TextBlock Text="Check interval" />
                <TextBox Text="{Binding CheckInterval}" />
            </DockPanel>
        </StackPanel>
        <Button
            Grid.Row="1"
            Width="200"
            HorizontalAlignment="Right"
            Command="{Binding CreateFeedSourceRequestCommand}"
            Content="Add web site"
            IsEnabled="{Binding CanCreateSource}" />

    </Grid>
</UserControl>
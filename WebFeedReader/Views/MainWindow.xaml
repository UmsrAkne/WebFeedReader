<Window
    x:Class="WebFeedReader.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:behaviors="clr-namespace:WebFeedReader.Behaviors"
    xmlns:controls="clr-namespace:WebFeedReader.Controls"
    xmlns:converters="clr-namespace:WebFeedReader.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:WebFeedReader.Models"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:viewModels="clr-namespace:WebFeedReader.ViewModels"
    xmlns:views="clr-namespace:WebFeedReader.Views"
    Title="{Binding Title}"
    Width="800"
    Height="400"
    d:DataContext="{d:DesignInstance viewModels:MainWindowViewModel}"
    prism:ViewModelLocator.AutoWireViewModel="True"
    Background="{StaticResource WindowBackgroundBrush}"
    mc:Ignorable="d">

    <Window.Resources>
        <converters:UtcToJstConverter x:Key="UtcToJstConverter" />
    </Window.Resources>

    <TabControl Background="{StaticResource ControlBackgroundBrush}">
        <TabItem Padding="15,4">
            <TabItem.Header>
                <TextBlock FontSize="{StaticResource CommonFontSize}" Text="Main" />
            </TabItem.Header>
            <Grid>

                <Grid.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{StaticResource CommonForegroundBrush}" />
                        <Setter Property="FontSize" Value="{StaticResource CommonFontSize}" />
                    </Style>

                    <Style TargetType="StatusBar">
                        <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}" />
                    </Style>

                    <Style TargetType="TabItem">
                        <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}" />
                    </Style>
                </Grid.Resources>

                <Grid.RowDefinitions>
                    <RowDefinition Height="80" />
                    <RowDefinition />
                    <RowDefinition Height="40" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <StatusBar
                    Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Padding="3">
                    <StackPanel Orientation="Horizontal">
                        <Button
                            Width="150"
                            Padding="4"
                            Command="{Binding ReloadAsyncCommand}"
                            Content="Reload" />

                        <ToggleButton
                            Width="150"
                            Margin="10,0"
                            Padding="4"
                            Command="{Binding FeedListViewModel.LoadAsyncCommand}"
                            Content="Filter (unread)"
                            IsChecked="{Binding FeedListViewModel.FeedSearchOption.IsUnreadOnly}" />

                        <ToggleButton
                            Width="200"
                            Padding="4"
                            Command="{Binding FeedListViewModel.LoadAsyncCommand}"
                            IsChecked="{Binding FeedListViewModel.FeedSearchOption.IsReverseOrder}">
                            <ToggleButton.Style>
                                <Style BasedOn="{StaticResource {x:Type ToggleButton}}" TargetType="ToggleButton">
                                    <Setter Property="Content" Value="Newest first" />
                                    <Style.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter Property="Content" Value="Oldest first (Filtered to 1 month)" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>

                    </StackPanel>
                </StatusBar>

                <Border
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="5"
                    Padding="3"
                    BorderBrush="{StaticResource LightBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="5">

                    <ListBox
                        Background="{StaticResource ControlBackgroundBrush}"
                        BorderThickness="0"
                        ItemsSource="{Binding FeedSourceListViewModel.Items}"
                        SelectedItem="{Binding FeedSourceListViewModel.SelectedItem}">

                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:FeedSource}">
                                <DataTemplate.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource CommonForegroundBrush}" />
                                        <Setter Property="FontSize" Value="{StaticResource CommonFontSize}" />
                                    </Style>
                                </DataTemplate.Resources>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="BorderBrush" Value="{StaticResource LightBorderBrush}" />
                                <Setter Property="BorderThickness" Value="0,0.5,0,0.5" />
                                <Setter Property="Padding" Value="5" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Border>

                <Border
                    Grid.Row="1"
                    Grid.Column="1"
                    Width="8"
                    Background="LightGray"
                    CornerRadius="3" />

                <GridSplitter
                    Grid.Row="1"
                    Grid.Column="1"
                    Width="8"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Background="Transparent" />

                <Grid Grid.Row="1" Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition Height="120" />
                    </Grid.RowDefinitions>

                    <Border
                        Margin="5"
                        Padding="3"
                        BorderBrush="{StaticResource LightBorderBrush}"
                        BorderThickness="0.5"
                        CornerRadius="5">
                        <ListBox
                            HorizontalContentAlignment="Stretch"
                            Background="{StaticResource ControlBackgroundBrush}"
                            BorderThickness="0"
                            ItemsSource="{Binding FeedListViewModel.Items}"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            SelectedItem="{Binding FeedListViewModel.SelectedItem}">
                            <ListBox.InputBindings>
                                <KeyBinding
                                    Key="C"
                                    Command="{Binding FeedListViewModel.CopyToClipboardCommand}"
                                    CommandParameter="{Binding FeedListViewModel.SelectedItem.Title}"
                                    Modifiers="Control" />

                                <KeyBinding
                                    Key="C"
                                    Command="{Binding FeedListViewModel.CopyToClipboardCommand}"
                                    CommandParameter="{Binding FeedListViewModel.SelectedItem.Summary}"
                                    Modifiers="Control+Shift" />

                                <KeyBinding
                                    Key="M"
                                    Command="{Binding FeedListViewModel.ToggleFavoriteCommand}"
                                    CommandParameter="{Binding FeedListViewModel.SelectedItem}" />

                                <KeyBinding
                                    Key="U"
                                    Command="{Binding FeedListViewModel.MarkAsUnreadCommand}"
                                    CommandParameter="{Binding FeedListViewModel.SelectedItem}" />

                                <KeyBinding Key="Escape" Command="{Binding FeedListViewModel.CancelSelectionCommand}" />

                            </ListBox.InputBindings>
                            <b:Interaction.Behaviors>
                                <behaviors:InfiniteScrollBehavior Threshold="20" />
                                <behaviors:ScrollResetBehavior />
                            </b:Interaction.Behaviors>

                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:FeedItem}">
                                    <DataTemplate.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontSize" Value="{StaticResource CommonFontSize}" />
                                            <Setter Property="Foreground" Value="{StaticResource CommonForegroundBrush}" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                        </Style>
                                    </DataTemplate.Resources>

                                    <ContentControl FocusVisualStyle="{x:Null}">
                                        <b:Interaction.Triggers>
                                            <b:EventTrigger EventName="MouseDoubleClick">
                                                <b:InvokeCommandAction Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=ListBox}, Path=DataContext.FeedListViewModel.OpenUrlAsyncCommand}" CommandParameter="{Binding Link}" />
                                            </b:EventTrigger>
                                        </b:Interaction.Triggers>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <!-- フィードの行番号 -->
                                                <TextBlock
                                                    Width="50"
                                                    Text="{Binding LineNumber, StringFormat=D4}"
                                                    TextAlignment="Center" />

                                                <!-- 範囲選択用チェックボックス -->

                                                <controls:CustomCheckBox
                                                    Margin="2,0"
                                                    VerticalAlignment="Center"
                                                    Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=ListBox}, Path=DataContext.FeedListViewModel.MarkRangeAsReadCommand}"
                                                    CommandParameter="{Binding}"
                                                    IsChecked="{Binding IsPreviewSelected}">
                                                    <b:Interaction.Triggers>
                                                        <b:EventTrigger EventName="MouseEnter">
                                                            <b:InvokeCommandAction Command="{Binding DataContext.FeedListViewModel.PreviewRangeCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=ListBox}}" CommandParameter="{Binding}" />
                                                        </b:EventTrigger>
                                                    </b:Interaction.Triggers>
                                                </controls:CustomCheckBox>

                                            </StackPanel>

                                            <!-- 未読マーク -->
                                            <Border
                                                Grid.Column="1"
                                                Margin="0,0,6,0"
                                                CornerRadius="3">

                                                <Border.Resources>
                                                    <Storyboard x:Key="FadeOutStoryboard">
                                                        <DoubleAnimation
                                                            Storyboard.TargetProperty="Opacity"
                                                            To="0"
                                                            Duration="0:0:0.2" />

                                                        <DoubleAnimation
                                                            Storyboard.TargetProperty="Height"
                                                            To="0"
                                                            Duration="0:0:0.4" />
                                                    </Storyboard>

                                                    <Storyboard x:Key="LoadStoryboard">
                                                        <DoubleAnimation
                                                            FillBehavior="Stop"
                                                            Storyboard.TargetProperty="Height"
                                                            To="16"
                                                            Duration="0:0:0.4" />
                                                        <ColorAnimation
                                                            BeginTime="0:0:0.2"
                                                            Storyboard.TargetProperty="Background.Color"
                                                            To="{StaticResource IndicatorColor}"
                                                            Duration="0:0:0.2" />
                                                    </Storyboard>

                                                    <Storyboard x:Key="FadeInStoryboard">
                                                        <DoubleAnimation
                                                            Storyboard.TargetProperty="Opacity"
                                                            To="1"
                                                            Duration="0:0:0.2" />
                                                        <DoubleAnimation
                                                            Storyboard.TargetProperty="Height"
                                                            To="16"
                                                            Duration="0:0:0.2" />
                                                    </Storyboard>
                                                </Border.Resources>

                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Height" Value="16" />
                                                        <Setter Property="Opacity" Value="1" />
                                                        <Setter Property="Background" Value="Transparent" />

                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRead}" Value="True">
                                                                <DataTrigger.EnterActions>
                                                                    <BeginStoryboard Name="FadeOutBegin" Storyboard="{StaticResource FadeOutStoryboard}" />
                                                                </DataTrigger.EnterActions>
                                                                <DataTrigger.ExitActions>
                                                                    <StopStoryboard BeginStoryboardName="FadeOutBegin" />
                                                                    <BeginStoryboard Storyboard="{StaticResource FadeInStoryboard}" />
                                                                </DataTrigger.ExitActions>
                                                            </DataTrigger>

                                                            <EventTrigger RoutedEvent="Loaded">
                                                                <BeginStoryboard Storyboard="{StaticResource LoadStoryboard}" />
                                                            </EventTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>

                                            <TextBlock
                                                Grid.Column="2"
                                                Width="20"
                                                Margin="2,0"
                                                VerticalAlignment="Center"
                                                FontSize="14"
                                                Text="★">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                                <Setter Property="Foreground" Value="Coral" />
                                                            </DataTrigger>

                                                            <DataTrigger Binding="{Binding IsFavorite}" Value="False">
                                                                <Setter Property="Foreground" Value="DimGray" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <TextBlock
                                                Grid.Column="3"
                                                Text="{Binding Title}"
                                                TextTrimming="CharacterEllipsis"
                                                TextWrapping="NoWrap" />
                                            <TextBlock
                                                Grid.Column="4"
                                                Width="120"
                                                Text="{Binding Published, Converter={StaticResource UtcToJstConverter}}"
                                                TextAlignment="Right" />
                                        </Grid>

                                    </ContentControl>
                                </DataTemplate>
                            </ListBox.ItemTemplate>

                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <!-- 基本 -->
                                    <Setter Property="Padding" Value="6,4" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                    <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}" />
                                    <Setter Property="BorderThickness" Value="2" />
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />

                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border
                                                    x:Name="Bd"
                                                    Padding="{TemplateBinding Padding}"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4"
                                                    SnapsToDevicePixels="True">

                                                    <ContentPresenter
                                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                        SnapsToDevicePixels="True" />
                                                </Border>

                                                <ControlTemplate.Triggers>

                                                    <!-- マウスオーバー -->
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Trigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <ColorAnimation
                                                                        Storyboard.TargetName="Bd"
                                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                        To="{StaticResource MouseOverBackgroundColor}"
                                                                        Duration="0:0:0.1" />
                                                                    <ColorAnimation
                                                                        Storyboard.TargetName="Bd"
                                                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                                        To="{StaticResource MouseOverBackgroundColor}"
                                                                        Duration="0:0:0.1" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.EnterActions>

                                                        <Trigger.ExitActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <ColorAnimation
                                                                        Storyboard.TargetName="Bd"
                                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                        To="{StaticResource LightBackgroundColor}"
                                                                        Duration="0:0:0.1" />
                                                                    <ColorAnimation
                                                                        Storyboard.TargetName="Bd"
                                                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                                        To="{StaticResource LightBackgroundColor}"
                                                                        Duration="0:0:0.1" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.ExitActions>
                                                    </Trigger>

                                                    <!-- 選択中 -->
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Trigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <ColorAnimation
                                                                        Storyboard.TargetName="Bd"
                                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                        To="#334A90E2"
                                                                        Duration="0:0:0.1" />
                                                                    <ColorAnimation
                                                                        Storyboard.TargetName="Bd"
                                                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                                        To="LightBlue"
                                                                        Duration="0:0:0.1" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.EnterActions>

                                                        <Trigger.ExitActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <ColorAnimation
                                                                        FillBehavior="Stop"
                                                                        Storyboard.TargetName="Bd"
                                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                        To="{StaticResource LightBackgroundColor}"
                                                                        Duration="0:0:0.1" />
                                                                    <ColorAnimation
                                                                        FillBehavior="Stop"
                                                                        Storyboard.TargetName="Bd"
                                                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                                        To="{StaticResource LightBackgroundColor}"
                                                                        Duration="0:0:0.1" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.ExitActions>
                                                    </Trigger>

                                                    <!-- 非アクティブ選択 -->
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsSelected" Value="True" />
                                                            <Condition Property="Selector.IsSelectionActive" Value="False" />
                                                        </MultiTrigger.Conditions>
                                                        <Setter TargetName="Bd" Property="Opacity" Value="0.8" />
                                                    </MultiTrigger>

                                                    <!-- 無効 -->
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter Property="Opacity" Value="0.5" />
                                                    </Trigger>

                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Border>

                    <Border
                        Grid.Row="1"
                        Margin="5"
                        BorderBrush="{StaticResource LightBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="5">
                        <TextBlock
                            Padding="3"
                            Text="{Binding FeedListViewModel.SelectedItem.Summary}"
                            TextWrapping="Wrap" />
                    </Border>
                </Grid>

                <StatusBar
                    Grid.Row="2"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Padding="5">
                    <StatusBarItem>
                        <TextBlock Text="{Binding FeedListViewModel.NgFilteredCount, StringFormat=NG除外: {0} 件}" />
                    </StatusBarItem>
                </StatusBar>
            </Grid>
        </TabItem>

        <TabItem Padding="15,4">
            <TabItem.Header>
                <TextBlock FontSize="{StaticResource CommonFontSize}" Text="Add Web site" />
            </TabItem.Header>
            <views:FeedSourceCreatePage DataContext="{Binding FeedSourceCreatePageViewModel}" />
        </TabItem>


        <TabItem Padding="15,4">
            <TabItem.Header>
                <TextBlock FontSize="{StaticResource CommonFontSize}" Text="Ng word" />
            </TabItem.Header>
            <views:NgListPage DataContext="{Binding NgListPageViewModel}" />
        </TabItem>

        <TabItem Padding="15,4">
            <TabItem.Header>
                <TextBlock FontSize="{StaticResource CommonFontSize}" Text="Setting" />
            </TabItem.Header>
            <views:SettingPage DataContext="{Binding SettingPageViewModel}" />
        </TabItem>
    </TabControl>

</Window>
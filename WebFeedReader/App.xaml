<prism:PrismApplication
    x:Class="WebFeedReader.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:system="clr-namespace:System;assembly=System.Runtime">
    <Application.Resources>
        <SolidColorBrush x:Key="LightBorderBrush" Color="LightSlateGray" />
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#333333" />
        <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#444444" />
        <SolidColorBrush x:Key="IndicatorColor" Color="DarkOrange" />
        <SolidColorBrush x:Key="CommonForegroundBrush" Color="GhostWhite" />

        <Color x:Key="LightBackgroundColor">
            #444444
        </Color>

        <Color x:Key="MouseOverBackgroundColor">
            #525252
        </Color>
        <system:Double x:Key="CommonFontSize">15</system:Double>
    </Application.Resources>
</prism:PrismApplication>